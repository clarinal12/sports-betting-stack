# Copy to .env.deploy and adjust.
# cp .env.deploy.example .env.deploy

# =============================================================================
# Mode A — local Docker (direct ports, no TLS)
# =============================================================================
PUBLIC_HOST=http://localhost
API_PUBLIC_URL=http://localhost:5003
BACKOFFICE_PUBLIC_URL=http://localhost:5001
PLAYER_PUBLIC_URL=http://localhost:5002
CORS_ORIGINS=http://localhost:5001,http://127.0.0.1:5001,http://localhost:5002,http://127.0.0.1:5002

# =============================================================================
# Mode B — public HTTPS (Caddy + Let's Encrypt on a VPS)
# Uncomment and fill in. Deploy with: ./deploy/up-https.sh
#
# 1. Point DNS A records at your server IP:
#      api.sports-dev.example.com
#      backoffice.sports-dev.example.com
#      play.sports-dev.example.com
# 2. Open firewall ports 80 and 443 (close 5001–5003 on the public interface).
# 3. Rebuild after changing URLs (NEXT_PUBLIC_* is baked at image build time).
# =============================================================================
# DOMAIN=sports-dev.example.com
# ACME_EMAIL=al.clarin.sagarino@gmail.com
# API_DOMAIN=api.sports-dev.example.com
# BACKOFFICE_DOMAIN=backoffice.sports-dev.example.com
# PLAYER_DOMAIN=play.sports-dev.example.com
# API_PUBLIC_URL=https://api.sports-dev.example.com
# BACKOFFICE_PUBLIC_URL=https://backoffice.sports-dev.example.com
# PLAYER_PUBLIC_URL=https://play.sports-dev.example.com
# CORS_ORIGINS=https://backoffice.sports-dev.example.com,https://play.sports-dev.example.com

# --- API (sports-betting-service) ---
NODE_ENV=development
PORT=5003
FIXTURE_PROVIDER=mock
SEED_ON_START=true

DATABASE_URL=postgresql://sports:sports@postgres:5432/sports_betting
REDIS_URL=redis://redis:6379
LOG_LEVEL=info
METRICS_ENABLED=true

STAFF_JWT_SECRET=dev-staff-jwt-secret-change-me-please
STAFF_ACCESS_TTL=15m
STAFF_REFRESH_TTL=7d

SESSION_JWT_SECRET=dev-session-secret-change-me-please
SESSION_TTL=30m
SECRET_ENCRYPTION_KEY=dev-encryption-key-change-me-please
AUTH_ALLOW_HEADER_FALLBACK=true
OPERATOR_JWT_CLOCK_SKEW=5

WALLET_PROVIDER=stub
WALLET_STUB_BALANCE=10000.00

RESULTS_INGEST_ENABLED=false
RESULTS_INGEST_POLL_SECONDS=120
SETTLEMENT_STALE_HOURS=6
ODDS_API_SCORES_DAYS_FROM=3
SETTLEMENT_ENABLED=false

REALTIME_SUBSCRIBE_MAX_PER_MINUTE=60

INGEST_LIVE_ENABLED=false
INGEST_LIVE_INTERVAL_SECONDS=60
INGEST_CATALOG_ENABLED=false
INGEST_CATALOG_CRON='0 */6 * * *'
INGEST_LIVE_PRESTART_MINUTES=15

# Optional: live odds ingest (requires ODDS_API_KEY and rebuild)
# FIXTURE_PROVIDER=odds-api
# ODDS_API_KEY=your-odds-api-key-here
# ODDS_API_SPORT_KEYS=basketball_nba
# ODDS_API_REGIONS=all
# ODDS_API_MARKETS=h2h,spreads,totals
# ODDS_API_ODDS_FORMAT=decimal
